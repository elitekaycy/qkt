STRATEGY broken_strategy VERSION 1

DEFAULTS {
    SIZING = RISK 0.01
    UNKNOWN_CLAUSE = something
    TIF = GTC
}

SYMBOLS
    btc = BYBIT:BTCUSDT EVERY 1m

LET
    x = 100

RULES
    WHEN btc.close > 100 THEN BUY btc SIZING 1 GARBAGE_HERE
    WHEN btc.close < 50 THEN ZAP btc
    WHEN btc.close > 200 THEN BUY btc
