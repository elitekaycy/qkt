# qkt project secrets — copy to .env and edit before `make up`.
#
# The compose file requires QKT_IMAGE_TAG to be set (no silent-downgrade default).
# Default below pins to the qkt version that scaffolded this project; bump it to
# move to a newer release.
QKT_IMAGE_TAG=v{{QKT_VERSION}}

# Bybit API credentials. Create a key pair at https://testnet.bybit.com/app/user/api-management
# for testnet (default) or https://www.bybit.com/app/user/api-management for mainnet.
# Required permissions: Read-Write on Spot and/or Derivatives (whichever you trade).
# Leaving these blank disables Bybit routing — the daemon will still start but won't
# accept Bybit symbols.
BYBIT_API_KEY=
BYBIT_API_SECRET=

# `true` → api-testnet.bybit.com (paper testnet, recommended until you're ready).
# `false` → api.bybit.com (real money).
BYBIT_TESTNET=true

# Telegram alerts (optional). Set TELEGRAM_ENABLED=true and provide bot creds to
# turn on. See docs/operations/monitoring.md.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
