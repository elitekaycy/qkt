-- Sample strategy — paper-trades against a backtest data source.
-- See https://elitekaycy.github.io/qkt/ for the DSL reference.

STRATEGY ema_cross VERSION 1

SYMBOLS
    btc = BACKTEST:BTCUSDT EVERY 1m WARMUP 21 BARS

RULES
    WHEN ema(btc.close, 9) CROSSES ABOVE ema(btc.close, 21)
     AND POSITION.btc = 0
    THEN BUY btc SIZING 1

    WHEN POSITION.btc > 0
     AND ema(btc.close, 9) CROSSES BELOW ema(btc.close, 21)
    THEN CLOSE btc
