services:
  init-perms:
    image: alpine:3
    # Pre-create the logs subdir on the host source so the daemon's
    # `Files.createDirectories(/var/lib/qkt/logs)` at startup succeeds inside
    # the single bind mount. See qkt-prod#1 for the failure mode this avoids.
    command: sh -c "mkdir -p /qkt-state/logs && chown -R 999:999 /qkt-state"
    volumes:
      - ./state:/qkt-state
    restart: "no"

  qkt:
    image: ghcr.io/elitekaycy/qkt:${QKT_IMAGE_TAG:?QKT_IMAGE_TAG must be set in .env}
    container_name: qkt
    restart: unless-stopped
    depends_on:
      init-perms:
        condition: service_completed_successfully
    command: ["--config", "/etc/qkt/qkt.config.yaml", "--control-port", "47000"]
    environment:
      QKT_STATE_DIR: /var/lib/qkt
    volumes:
      - ./strategies:/strategies:ro
      - ./qkt.config.yaml:/etc/qkt/qkt.config.yaml:ro
      # Single bind for the daemon's state dir. The daemon writes its `logs/`
      # subdir inside this bind, persisted to `./state/logs/` on host. Avoid
      # nesting a separate `./logs:/var/lib/qkt/logs` mount — Docker handles
      # nested bind mounts unreliably and the inner mount can fail silently.
      - ./state:/var/lib/qkt
    healthcheck:
      test: ["CMD", "qkt", "list"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "5"
