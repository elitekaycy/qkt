# qkt project secrets — copy to .env and edit before `make up`.
#
# The compose file requires QKT_IMAGE_TAG to be set (no silent-downgrade default).
# Default below pins to the qkt version that scaffolded this project; bump it to
# move to a newer release.
QKT_IMAGE_TAG=v{{QKT_VERSION}}

# Per-deployment broker magic number — only matters when you have multiple qkt
# instances against the same MT5 account so orders can be told apart.
QKT_EXNESS_MAGIC=10001

# MT5 VNC desktop access (for the one-time broker login through the gateway's
# web VNC at http://127.0.0.1:3020 via SSH tunnel). Change these from the defaults.
MT5_VNC_USER=admin
MT5_VNC_PASSWORD=changeme
MT5_LOG_LEVEL=INFO

# Headless broker login (optional). Set these and the gateway logs into the
# broker on boot — no VNC needed. Leave MT5_LOGIN empty to use the one-time VNC
# flow above. The broker directory (servers.dat) ships baked in the :bot image.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Exness-MT5Trial9

# Telegram alerts (optional). Set TELEGRAM_ENABLED=true and provide bot creds to
# turn on. See docs/operations/monitoring.md.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
