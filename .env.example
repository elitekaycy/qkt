# Copy to .env and fill in. Used by docker-compose.yml.

# MT5 broker login — provided by your broker (Exness, ICMarkets, FTMO, etc.)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Exness-MT5Real8        # broker-specific server identifier

# VNC for connecting to the MT5 GUI inside the gateway container.
# Used to log in on first start.
VNC_PASSWORD=changeme
